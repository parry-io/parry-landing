# ── Parry Data Room ───────────────────────────────────────────────────────
# Copy to .env.local for local dev, and set the same vars in the Vercel project
# (Production + Preview) before going live. None are required for local dev.

# Session signing secret — REQUIRED in production (>= 16 chars).
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
DATAROOM_SESSION_SECRET=

# Email notifications — sent on every login and every document view.
# Gmail / Google Workspace SMTP. If no user+pass is set, emails are logged to
# the server console instead of being sent.
#
# NOTE: parry-core's variable names are also accepted, so the SAME Parry Gmail
# SMTP credentials work unchanged — set EMAIL_USER + EMAIL_PASS (the values in
# GCP Secret Manager `email-user` / `email-pass`) instead of SMTP_USER/SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Parry Data Room <check@parry-io.com>"
# Alternative (parry-core names) — pick ONE pair:
# EMAIL_USER=check@parry-io.com
# EMAIL_PASS=<gmail app password>  (GCP Secret Manager: email-pass)

# Recipients of the alerts (comma-separated). Defaults to the two below if unset.
DATAROOM_NOTIFY_TO=tomer@parry-io.com, yehonatan@parry-io.com
