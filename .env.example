# ── Parry Data Room ───────────────────────────────────────────────────────
# Copy to .env.local for local dev, and set the same vars in the Vercel project
# (Production + Preview) before going live. None are required for local dev.

# Session signing secret — REQUIRED in production (>= 16 chars).
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
DATAROOM_SESSION_SECRET=

# Email notifications — sent on every login and every document view.
# Use a Gmail / Google Workspace account with 2FA + an App Password.
# If SMTP_HOST is empty, emails are logged to the server console instead of sent.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tomer@parry-io.com
SMTP_PASS=
SMTP_FROM="Parry Data Room <tomer@parry-io.com>"

# Recipients of the alerts (comma-separated). Defaults to the two below if unset.
DATAROOM_NOTIFY_TO=tomer@parry-io.com, yehonatan@parry-io.com
